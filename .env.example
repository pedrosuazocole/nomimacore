# =====================================================
# NominaCore HN - Variables de Configuracion
# Copia este archivo como ".env" y ajusta los valores
# =====================================================

# Servidor
PORT=3000
NODE_ENV=production
APP_URL=https://tuapp.up.railway.app

# Base de datos SQLite
# En Railway usa el volumen persistente, ej: /data/nominacore.db
DB_PATH=./data/nominacore.db

# Empresa (aparece en encabezados de reportes)
EMPRESA_NOMBRE=Mi Empresa S.A.
EMPRESA_RTN=0000-0000-000000

# Parametros legales de jornada (Codigo de Trabajo de Honduras)
# Pueden ajustarse tambien desde el modulo de Configuracion en la app
HORAS_JORNADA_DIURNA=44
HORAS_JORNADA_NOCTURNA=36
HORAS_JORNADA_MIXTA=42

# Recargos por hora extra (multiplicadores sobre la hora ordinaria)
RECARGO_25=1.25
RECARGO_50=1.50
RECARGO_75=1.75
RECARGO_100=2.00

# IHSS / RAP - IMPORTANTE:
# Estos valores deben verificarse contra las tablas oficiales vigentes
# del IHSS y del RAP (cambian periodicamente). No se deben asumir como
# definitivos. Configuralos en el modulo "Configuracion" de la app.
IHSS_PORCENTAJE_EMPLEADO=0.035
IHSS_TECHO_SALARIAL=11903.13
RAP_PORCENTAJE_EMPLEADO=0.015
RAP_TECHO_SALARIAL=11903.13

# Sesion / seguridad
SESSION_SECRET=cambia_este_valor_por_uno_seguro_y_largo

# Usuario administrador creado automaticamente en el primer arranque
# (solo si la tabla de usuarios esta vacia). Cambia la contraseña
# desde el modulo Usuarios inmediatamente despues del primer login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=NominaCore2026!

# WhatsApp de contacto (pie de pagina de reportes)
WHATSAPP_CONTACTO=94502710
