<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-5">
    <h1 class="text-2xl font-bold text-[#1B2A4A]">Empleados</h1>
    <a href="/empleados/nuevo" class="btn btn-primary">+ Nuevo Empleado</a>
</div>

<form method="GET" class="card mb-5 grid grid-cols-1 md:grid-cols-4 gap-3">
    <input class="input" type="text" name="q" placeholder="Buscar por nombre o codigo..." value="<%= filtros.q || '' %>">
    <select class="input" name="departamento">
        <option value="">Todos los departamentos</option>
        <% departamentos.forEach(d => { %>
            <option value="<%= d %>" <%= filtros.departamento === d ? 'selected' : '' %>><%= d %></option>
        <% }) %>
    </select>
    <select class="input" name="estado">
        <option value="">Todos los estados</option>
        <option value="ACTIVO" <%= filtros.estado === 'ACTIVO' ? 'selected' : '' %>>Activo</option>
        <option value="INACTIVO" <%= filtros.estado === 'INACTIVO' ? 'selected' : '' %>>Inactivo</option>
    </select>
    <button class="btn btn-secondary">Filtrar</button>
</form>

<div class="card table-scroll">
    <table class="table-nomina">
        <thead>
            <tr>
                <th>Codigo</th><th>Nombre</th><th>Departamento</th><th>Cuenta Contable</th>
                <th>Salario Base</th><th>Jornada</th><th>Estado</th><th></th>
            </tr>
        </thead>
        <tbody>
        <% if (empleados.length === 0) { %>
            <tr><td colspan="8" class="text-center text-slate-500 py-6">No hay empleados registrados todavia.</td></tr>
        <% } %>
        <% empleados.forEach(e => { %>
            <tr>
                <td><%= e.codigo_contable || '—' %></td>
                <td class="font-medium"><%= e.nombre_completo %></td>
                <td><%= e.departamento %></td>
                <td><%= e.cuenta_contable || '—' %></td>
                <td>L. <%= Number(e.salario_base).toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td><span class="text-xs px-2 py-1 rounded-full bg-slate-100"><%= e.tipo_jornada %></span></td>
                <td>
                    <span class="text-xs px-2 py-1 rounded-full <%= e.estado === 'ACTIVO' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>">
                        <%= e.estado %>
                    </span>
                </td>
                <td class="whitespace-nowrap">
                    <a href="/empleados/<%= e.id %>/editar" class="text-[#0D9488] font-medium mr-3">Editar</a>
                    <form method="POST" action="/empleados/<%= e.id %>?_method=DELETE" class="inline" onsubmit="return confirm('¿Dar de baja a este empleado?');">
                        <button class="text-red-600 font-medium">Baja</button>
                    </form>
                </td>
            </tr>
        <% }) %>
        </tbody>
    </table>
</div>
