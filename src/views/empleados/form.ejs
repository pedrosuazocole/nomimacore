<h1 class="text-2xl font-bold text-[#1B2A4A] mb-5"><%= title %></h1>

<% if (errores && errores.length) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-300 text-red-700 px-4 py-3 text-sm">
        <ul class="list-disc pl-5">
            <% errores.forEach(e => { %><li><%= e %></li><% }) %>
        </ul>
    </div>
<% } %>

<form method="POST" action="<%= empleado.id ? '/empleados/' + empleado.id + '?_method=PUT' : '/empleados' %>" class="card grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
        <label class="block text-sm font-medium mb-1">Nombre Completo *</label>
        <input class="input" type="text" name="nombre_completo" required value="<%= empleado.nombre_completo || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Codigo Contable</label>
        <input class="input" type="text" name="codigo_contable" placeholder="ej: 1106-01-26" value="<%= empleado.codigo_contable || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Departamento</label>
        <input class="input" type="text" name="departamento" value="<%= empleado.departamento || 'General' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Cargo</label>
        <input class="input" type="text" name="cargo" value="<%= empleado.cargo || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Empresa</label>
        <input class="input" type="text" name="empresa" placeholder="ej: Inversiones Buenos Aires S.A." value="<%= empleado.empresa || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Cuenta Contable del Empleado</label>
        <input class="input" type="text" name="cuenta_contable" value="<%= empleado.cuenta_contable || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Salario Base (Mensual) *</label>
        <input class="input" type="number" step="0.01" min="0" name="salario_base" required value="<%= empleado.salario_base || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Tipo de Pago</label>
        <select class="input" name="tipo_pago">
            <% ['MENSUAL','QUINCENAL','SEMANAL','HORA'].forEach(tp => { %>
                <option value="<%= tp %>" <%= empleado.tipo_pago === tp ? 'selected' : '' %>><%= tp %></option>
            <% }) %>
        </select>
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Tipo de Jornada</label>
        <select class="input" name="tipo_jornada">
            <option value="DIURNA" <%= empleado.tipo_jornada === 'DIURNA' ? 'selected' : '' %>>Diurna (44 h/semana)</option>
            <option value="NOCTURNA" <%= empleado.tipo_jornada === 'NOCTURNA' ? 'selected' : '' %>>Nocturna (36 h/semana)</option>
            <option value="MIXTA" <%= empleado.tipo_jornada === 'MIXTA' ? 'selected' : '' %>>Mixta (42 h/semana)</option>
        </select>
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Fecha de Ingreso</label>
        <input class="input" type="date" name="fecha_ingreso" value="<%= empleado.fecha_ingreso || '' %>">
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Estado</label>
        <select class="input" name="estado">
            <option value="ACTIVO" <%= empleado.estado === 'ACTIVO' ? 'selected' : '' %>>Activo</option>
            <option value="INACTIVO" <%= empleado.estado === 'INACTIVO' ? 'selected' : '' %>>Inactivo</option>
        </select>
    </div>

    <div class="md:col-span-2 flex gap-3 pt-2">
        <button class="btn btn-primary">Guardar</button>
        <a href="/empleados" class="btn btn-outline">Cancelar</a>
    </div>
</form>
