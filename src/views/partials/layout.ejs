<!DOCTYPE html>
<html lang="es-HN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' | NominaCore HN' : 'NominaCore HN' %></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="/css/estilos.css">
</head>
<body class="bg-slate-100 text-slate-800 min-h-screen flex flex-col">

<!-- ============ NAVBAR ============ -->
<header class="bg-[#1B2A4A] text-white shadow-md no-print">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between flex-wrap gap-3">
        <a href="/planillas" class="flex items-center gap-2 font-bold text-lg">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[#0D9488]">🧾</span>
            NominaCore <span class="text-[#D97A2C]">HN</span>
        </a>
        <button id="menuBtn" class="md:hidden text-white text-2xl leading-none">☰</button>
        <nav id="navLinks" class="w-full md:w-auto hidden md:flex flex-col md:flex-row gap-1 md:gap-2 text-sm font-medium items-center">
            <a href="/planillas" class="nav-link <%= currentPath && currentPath.startsWith('/planillas') ? 'nav-active' : '' %>">Planillas</a>
            <a href="/turnos" class="nav-link <%= currentPath && currentPath.startsWith('/turnos') ? 'nav-active' : '' %>">Horarios</a>
            <a href="/empleados" class="nav-link <%= currentPath && currentPath.startsWith('/empleados') ? 'nav-active' : '' %>">Empleados</a>
            <% if (usuarioActual && usuarioActual.rol === 'ADMIN') { %>
                <a href="/usuarios" class="nav-link <%= currentPath && currentPath.startsWith('/usuarios') ? 'nav-active' : '' %>">Usuarios</a>
            <% } %>
            <a href="/configuracion" class="nav-link <%= currentPath && currentPath.startsWith('/configuracion') ? 'nav-active' : '' %>">Configuracion</a>
            <% if (usuarioActual) { %>
                <span class="text-slate-300 text-xs px-2 hidden md:inline">|</span>
                <span class="text-slate-300 text-xs px-2"><%= usuarioActual.nombre %> · <%= usuarioActual.rol %></span>
                <form method="POST" action="/logout" class="inline">
                    <button class="nav-link bg-red-600/80 hover:bg-red-600">Salir</button>
                </form>
            <% } %>
        </nav>
    </div>
</header>

<!-- ============ CONTENIDO ============ -->
<main class="flex-1 max-w-7xl w-full mx-auto px-4 py-6">
    <% if (typeof ok !== 'undefined' && ok) { %>
        <div class="mb-4 rounded-lg bg-emerald-50 border border-emerald-300 text-emerald-800 px-4 py-3 text-sm no-print">
            ✅ <%= ok %>
        </div>
    <% } %>
    <%- body %>
</main>

<!-- ============ FOOTER ============ -->
<footer class="bg-[#1B2A4A] text-slate-200 text-sm no-print">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col md:flex-row items-center justify-between gap-3">
        <p>&copy; <%= new Date().getFullYear() %> <span class="text-[#0D9488] font-semibold">Metric Solutions &amp; POS</span> — Todos los derechos reservados.</p>
        <a href="https://wa.me/504<%= (appConfig && appConfig.whatsapp_contacto) || '94502710' %>" target="_blank" rel="noopener"
           class="flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe57] text-white px-3 py-1.5 rounded-full font-medium transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M16.001 3C9.373 3 4 8.373 4 15c0 2.386.696 4.61 1.897 6.487L4 29l7.714-1.862A11.94 11.94 0 0 0 16.001 27C22.629 27 28 21.627 28 15S22.629 3 16.001 3zm0 21.75c-1.96 0-3.79-.55-5.35-1.5l-.384-.229-4.578 1.105 1.127-4.463-.25-.4A9.71 9.71 0 0 1 5.25 15c0-5.93 4.82-10.75 10.751-10.75S26.75 9.07 26.75 15 21.932 24.75 16.001 24.75zm5.6-7.99c-.307-.154-1.816-.897-2.098-1-.281-.103-.486-.154-.69.154-.205.307-.792 1-.97 1.205-.179.205-.358.23-.665.077-.307-.154-1.296-.478-2.469-1.524-.912-.813-1.528-1.817-1.707-2.124-.179-.307-.019-.473.135-.626.138-.138.307-.358.46-.537.154-.179.205-.307.307-.512.103-.205.051-.384-.026-.537-.077-.154-.69-1.663-.945-2.278-.249-.598-.502-.517-.69-.527l-.588-.01c-.205 0-.537.077-.818.384-.281.307-1.073 1.048-1.073 2.557 0 1.51 1.098 2.968 1.25 3.173.154.205 2.16 3.298 5.234 4.625.731.316 1.301.505 1.746.646.734.234 1.402.2 1.93.121.589-.088 1.816-.742 2.072-1.459.256-.717.256-1.331.18-1.459-.077-.128-.282-.205-.589-.358z"/>
            </svg>
            +504 <%= (appConfig && appConfig.whatsapp_contacto) || '9450-2710' %>
        </a>
    </div>
</footer>

<script>
document.getElementById('menuBtn')?.addEventListener('click', () => {
    document.getElementById('navLinks').classList.toggle('hidden');
});
// Cierra el menu movil automaticamente al tocar un enlace, para no
// tener que cerrarlo manualmente despues de cada navegacion.
document.querySelectorAll('#navLinks a').forEach(link => {
    link.addEventListener('click', () => {
        if (window.innerWidth < 768) {
            document.getElementById('navLinks').classList.add('hidden');
        }
    });
});
</script>
</body>
</html>
