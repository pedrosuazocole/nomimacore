<div class="mb-5 no-print">
    <a href="/reportes" class="text-sm text-[#0D9488]">&larr; Volver a Reportes</a>
</div>

<form method="GET" class="card mb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 no-print">
    <div>
        <label class="block text-xs font-medium mb-1">Estado</label>
        <select class="input" name="estado">
            <option value="">Todos</option>
            <option value="ACTIVO" <%= filtros.estado === 'ACTIVO' ? 'selected' : '' %>>Activo</option>
            <option value="INACTIVO" <%= filtros.estado === 'INACTIVO' ? 'selected' : '' %>>Inactivo</option>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Departamento</label>
        <select class="input" name="departamento">
            <option value="">Todos</option>
            <% departamentos.forEach(d => { %><option value="<%= d %>" <%= filtros.departamento === d ? 'selected' : '' %>><%= d %></option><% }) %>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Empresa</label>
        <select class="input" name="empresa">
            <option value="">Todas</option>
            <% empresas.forEach(e => { %><option value="<%= e %>" <%= filtros.empresa === e ? 'selected' : '' %>><%= e %></option><% }) %>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Jornada</label>
        <select class="input" name="tipo_jornada">
            <option value="">Todas</option>
            <option value="DIURNA" <%= filtros.tipo_jornada === 'DIURNA' ? 'selected' : '' %>>Diurna</option>
            <option value="NOCTURNA" <%= filtros.tipo_jornada === 'NOCTURNA' ? 'selected' : '' %>>Nocturna</option>
            <option value="MIXTA" <%= filtros.tipo_jornada === 'MIXTA' ? 'selected' : '' %>>Mixta</option>
        </select>
    </div>
    <div class="flex items-end">
        <button class="btn btn-secondary w-full">Filtrar</button>
    </div>
</form>

<div class="flex flex-wrap gap-2 mb-5 no-print">
    <button onclick="window.print()" class="btn btn-outline">🖨️ Imprimir</button>
    <a href="?<%= new URLSearchParams({...filtros, export: 'xlsx'}).toString() %>" class="btn btn-accent">📊 Exportar a Excel</a>
</div>

<%- include('../partials/reporte_header', {
    tituloReporte: 'Padron de Empleados',
    subtitulo: `Estado: ${filtros.estado || 'Todos'} · ${filas.length} empleado(s)`
}) %>

<% if (filas.length === 0) { %>
    <div class="reporte-vacio avoid-break">
        <div class="reporte-vacio__icon">👥</div>
        <p class="font-medium text-slate-600">No hay empleados que coincidan con el filtro.</p>
    </div>
<% } else { %>
<div class="card table-scroll">
    <table class="table-nomina">
        <thead><tr><th>Nombre</th><th>Codigo</th><th>Departamento</th><th>Cargo</th><th>Empresa</th><th>Salario Base</th><th>Jornada</th><th>Ingreso</th><th>Estado</th></tr></thead>
        <tbody>
        <% filas.forEach(e => { %>
            <tr class="avoid-break">
                <td class="font-medium"><%= e.nombre_completo %></td>
                <td><%= e.codigo_contable || '—' %></td>
                <td><%= e.departamento %></td>
                <td><%= e.cargo || '—' %></td>
                <td><%= e.empresa || '—' %></td>
                <td>L. <%= Number(e.salario_base).toLocaleString('es-HN',{minimumFractionDigits:2}) %></td>
                <td><%= e.tipo_jornada %></td>
                <td><%= e.fecha_ingreso || '—' %></td>
                <td><span class="text-xs px-2 py-1 rounded-full <%= e.estado === 'ACTIVO' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>"><%= e.estado %></span></td>
            </tr>
        <% }) %>
        </tbody>
    </table>
</div>
<% } %>

<%- include('../partials/reporte_footer') %>
