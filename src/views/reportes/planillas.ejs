<div class="flex items-center justify-between mb-5 no-print">
    <div>
        <h1 class="text-2xl font-bold text-[#1B2A4A]">Resumen de Planillas por Periodo</h1>
        <a href="/reportes" class="text-sm text-[#0D9488]">&larr; Volver a Reportes</a>
    </div>
</div>

<form method="GET" class="card mb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3 no-print">
    <div>
        <label class="block text-xs font-medium mb-1">Desde</label>
        <input class="input" type="date" name="fecha_inicio" value="<%= filtros.fecha_inicio %>">
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Hasta</label>
        <input class="input" type="date" name="fecha_fin" value="<%= filtros.fecha_fin %>">
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Tipo Periodo</label>
        <select class="input" name="tipo_periodo">
            <option value="">Todos</option>
            <option value="SEMANAL" <%= filtros.tipo_periodo === 'SEMANAL' ? 'selected' : '' %>>Semanal</option>
            <option value="QUINCENAL" <%= filtros.tipo_periodo === 'QUINCENAL' ? 'selected' : '' %>>Quincenal</option>
            <option value="MENSUAL" <%= filtros.tipo_periodo === 'MENSUAL' ? 'selected' : '' %>>Mensual</option>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Empresa</label>
        <select class="input" name="empresa">
            <option value="">Todas</option>
            <% empresas.forEach(e => { %><option value="<%= e %>" <%= filtros.empresa === e ? 'selected' : '' %>><%= e %></option><% }) %>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Estado</label>
        <select class="input" name="estado">
            <option value="">Todos</option>
            <option value="BORRADOR" <%= filtros.estado === 'BORRADOR' ? 'selected' : '' %>>Borrador</option>
            <option value="PROCESADA" <%= filtros.estado === 'PROCESADA' ? 'selected' : '' %>>Procesada</option>
            <option value="PAGADA" <%= filtros.estado === 'PAGADA' ? 'selected' : '' %>>Pagada</option>
        </select>
    </div>
    <div class="flex items-end">
        <button class="btn btn-secondary w-full">Filtrar</button>
    </div>
</form>

<div class="flex flex-wrap gap-2 mb-5 no-print">
    <button onclick="window.print()" class="btn btn-outline">🖨️ Imprimir</button>
    <a href="?<%= new URLSearchParams({...filtros, export: 'xlsx'}).toString() %>" class="btn btn-accent">📊 Exportar a Excel</a>
</div>

<div class="text-center mb-4 hidden print:block">
    <h1 class="text-xl font-bold text-[#1B2A4A]">Resumen de Planillas por Periodo</h1>
    <p class="text-sm text-slate-600"><%= filtros.fecha_inicio %> al <%= filtros.fecha_fin %></p>
</div>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
    <div class="card text-center avoid-break">
        <p class="text-xl font-bold text-[#1B2A4A]">L. <%= totales.total_salarios.toLocaleString('es-HN', {minimumFractionDigits:2}) %></p>
        <p class="text-xs text-slate-500">Salarios</p>
    </div>
    <div class="card text-center avoid-break">
        <p class="text-xl font-bold text-[#D97A2C]">L. <%= totales.total_extras.toLocaleString('es-HN', {minimumFractionDigits:2}) %></p>
        <p class="text-xs text-slate-500">Horas Extra</p>
    </div>
    <div class="card text-center avoid-break">
        <p class="text-xl font-bold text-red-600">L. <%= totales.total_deducciones.toLocaleString('es-HN', {minimumFractionDigits:2}) %></p>
        <p class="text-xs text-slate-500">Deducciones</p>
    </div>
    <div class="card text-center avoid-break bg-teal-50 border border-teal-200">
        <p class="text-xl font-bold text-[#0D9488]">L. <%= totales.total_pagar.toLocaleString('es-HN', {minimumFractionDigits:2}) %></p>
        <p class="text-xs text-slate-500">Total a Pagar</p>
    </div>
</div>

<div class="card table-scroll">
    <table class="table-nomina">
        <thead><tr><th>Planilla</th><th>Tipo</th><th>Empresa</th><th>Periodo</th><th>Estado</th><th>Salarios</th><th>Extras</th><th>Deducciones</th><th>Total a Pagar</th></tr></thead>
        <tbody>
        <% if (filas.length === 0) { %>
            <tr><td colspan="9" class="text-center text-slate-500 py-6">No hay planillas en el rango seleccionado.</td></tr>
        <% } %>
        <% filas.forEach(p => { %>
            <tr class="avoid-break">
                <td class="font-medium"><%= p.nombre %></td>
                <td><%= p.tipo_periodo %></td>
                <td><%= p.empresa || '—' %></td>
                <td><%= p.fecha_inicio %> al <%= p.fecha_fin %></td>
                <td><span class="text-xs px-2 py-1 rounded-full <%= p.estado === 'PROCESADA' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>"><%= p.estado %></span></td>
                <td>L. <%= Number(p.total_salarios).toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td>L. <%= Number(p.total_extras).toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td>L. <%= Number(p.total_deducciones).toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td class="font-bold">L. <%= Number(p.total_pagar).toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
            </tr>
        <% }) %>
        </tbody>
        <% if (filas.length > 0) { %>
        <tfoot>
            <tr class="font-bold bg-slate-50">
                <td colspan="5">TOTALES</td>
                <td>L. <%= totales.total_salarios.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td>L. <%= totales.total_extras.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td>L. <%= totales.total_deducciones.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                <td>L. <%= totales.total_pagar.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
            </tr>
        </tfoot>
        <% } %>
    </table>
</div>
