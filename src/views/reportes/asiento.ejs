<div class="mb-5 no-print">
    <a href="/reportes" class="text-sm text-[#0D9488]">&larr; Volver a Reportes</a>
</div>

<form method="GET" class="card mb-5 grid grid-cols-1 sm:grid-cols-4 gap-3 no-print">
    <div>
        <label class="block text-xs font-medium mb-1">Desde</label>
        <input class="input" type="date" name="fecha_inicio" value="<%= filtros.fecha_inicio %>">
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Hasta</label>
        <input class="input" type="date" name="fecha_fin" value="<%= filtros.fecha_fin %>">
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Empresa</label>
        <select class="input" name="empresa">
            <option value="">Todas</option>
            <% empresas.forEach(e => { %><option value="<%= e %>" <%= filtros.empresa === e ? 'selected' : '' %>><%= e %></option><% }) %>
        </select>
    </div>
    <div class="flex items-end">
        <button class="btn btn-secondary w-full">Filtrar</button>
    </div>
</form>

<div class="flex flex-wrap gap-2 mb-5 no-print">
    <button onclick="window.print()" class="btn btn-outline">🖨️ Imprimir</button>
    <a href="?<%= new URLSearchParams({...filtros, export: 'xlsx'}).toString() %>" class="btn btn-accent">📊 Exportar a Excel</a>
    <a href="/reportes/contable?<%= new URLSearchParams(filtros).toString() %>" class="btn btn-outline">📗 Ver Reporte Contable (resumen Debe/Haber)</a>
</div>

<%- include('../partials/reporte_header', {
    tituloReporte: 'Asiento Contable de Nomina',
    subtitulo: `${filtros.fecha_inicio} al ${filtros.fecha_fin}${filtros.empresa ? ' — ' + filtros.empresa : ''}`
}) %>

<% if (planillasIncluidas.length === 0) { %>
    <div class="reporte-vacio avoid-break">
        <div class="reporte-vacio__icon">🧾</div>
        <p class="font-medium text-slate-600">No hay planillas procesadas en este rango.</p>
        <p class="text-sm">Ajusta las fechas o procesa una planilla primero.</p>
    </div>
<% } else { %>

<div class="card mb-5 text-xs text-slate-600 avoid-break">
    <strong class="text-[#1B2A4A]">Planillas incluidas en este asiento:</strong>
    <%= planillasIncluidas.map(p => `${p.nombre} (${p.fecha_inicio} al ${p.fecha_fin})`).join(' · ') %>
</div>

<div class="card mb-5 avoid-break">
    <div class="flex items-center justify-between mb-3">
        <h2 class="font-bold text-[#1B2A4A]">Partida de Diario</h2>
        <% if (cuadra) { %>
            <span class="text-xs px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 font-semibold">✓ Cuadrado (Debe = Haber)</span>
        <% } else { %>
            <span class="text-xs px-3 py-1 rounded-full bg-red-100 text-red-700 font-semibold">⚠ No cuadra — revisar</span>
        <% } %>
    </div>

    <div class="table-scroll">
        <table class="table-nomina">
            <thead><tr><th>Codigo de Cuenta</th><th>Cuenta</th><th class="text-right">Debe</th><th class="text-right">Haber</th></tr></thead>
            <tbody>
            <% lineas.forEach(l => { %>
                <tr class="avoid-break">
                    <td class="whitespace-nowrap font-mono text-xs"><%= l.codigo %></td>
                    <td><%= l.cuenta %></td>
                    <td class="text-right"><%= l.debe > 0 ? 'L. ' + l.debe.toLocaleString('es-HN', {minimumFractionDigits:2}) : '—' %></td>
                    <td class="text-right"><%= l.haber > 0 ? 'L. ' + l.haber.toLocaleString('es-HN', {minimumFractionDigits:2}) : '—' %></td>
                </tr>
            <% }) %>
            </tbody>
            <tfoot>
                <tr class="font-bold bg-slate-50 border-t-2 border-[#1B2A4A]">
                    <td colspan="2">TOTALES</td>
                    <td class="text-right"><%= totalDebe.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                    <td class="text-right"><%= totalHaber.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="grid grid-cols-2 gap-8 mt-10 text-sm avoid-break">
    <div class="firma-linea-asiento text-center border-t border-slate-400 pt-2">Elaborado por</div>
    <div class="firma-linea-asiento text-center border-t border-slate-400 pt-2">Autorizado por</div>
</div>

<% } %>

<%- include('../partials/reporte_footer') %>
