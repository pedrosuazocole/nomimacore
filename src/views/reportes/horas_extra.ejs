<div class="mb-5 no-print">
    <a href="/reportes" class="text-sm text-[#0D9488]">&larr; Volver a Reportes</a>
</div>

<form method="GET" class="card mb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 no-print">
    <div>
        <label class="block text-xs font-medium mb-1">Desde</label>
        <input class="input" type="date" name="fecha_inicio" value="<%= filtros.fecha_inicio %>">
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Hasta</label>
        <input class="input" type="date" name="fecha_fin" value="<%= filtros.fecha_fin %>">
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Empleado</label>
        <select class="input" name="empleado_id">
            <option value="">Todos</option>
            <% empleados.forEach(e => { %><option value="<%= e.id %>" <%= String(filtros.empleado_id) === String(e.id) ? 'selected' : '' %>><%= e.nombre_completo %></option><% }) %>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium mb-1">Departamento</label>
        <select class="input" name="departamento">
            <option value="">Todos</option>
            <% departamentos.forEach(d => { %><option value="<%= d %>" <%= filtros.departamento === d ? 'selected' : '' %>><%= d %></option><% }) %>
        </select>
    </div>
    <div class="flex items-end">
        <button class="btn btn-secondary w-full">Filtrar</button>
    </div>
</form>

<div class="flex flex-wrap gap-2 mb-5 no-print">
    <button onclick="window.print()" class="btn btn-outline">🖨️ Imprimir</button>
    <a href="?<%= new URLSearchParams({...filtros, export: 'xlsx'}).toString() %>" class="btn btn-accent">📊 Exportar a Excel</a>
</div>

<%- include('../partials/reporte_header', {
    tituloReporte: 'Reporte de Horas Extra',
    subtitulo: `${filtros.fecha_inicio} al ${filtros.fecha_fin}`
}) %>

<div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-5">
    <div class="stat-card stat-card--navy avoid-break">
        <span class="stat-card__icon">⏱️</span>
        <div><p class="stat-card__value"><%= totales.horas_extras_total %> h</p><p class="stat-card__label">Total Horas</p></div>
    </div>
    <div class="stat-card avoid-break" style="border-left-color:#f59e0b">
        <span class="stat-card__icon">🌤️</span>
        <div><p class="stat-card__value" style="color:#f59e0b"><%= totales.horas_bucket_25 %> h</p><p class="stat-card__label">25% (2pm-7pm)</p></div>
    </div>
    <div class="stat-card stat-card--orange avoid-break">
        <span class="stat-card__icon">🌆</span>
        <div><p class="stat-card__value"><%= totales.horas_bucket_50 %> h</p><p class="stat-card__label">50% (7pm-9pm)</p></div>
    </div>
    <div class="stat-card stat-card--purple avoid-break">
        <span class="stat-card__icon">🌙</span>
        <div><p class="stat-card__value"><%= totales.horas_bucket_75 %> h</p><p class="stat-card__label">75% (Nocturno)</p></div>
    </div>
    <div class="stat-card stat-card--total avoid-break">
        <span class="stat-card__icon">💵</span>
        <div><p class="stat-card__value">L. <%= totales.pago_total_extras.toLocaleString('es-HN', {minimumFractionDigits:2}) %></p><p class="stat-card__label">Pago Total</p></div>
    </div>
</div>

<% if (filas.length === 0) { %>
    <div class="reporte-vacio avoid-break">
        <div class="reporte-vacio__icon">⏱️</div>
        <p class="font-medium text-slate-600">No hay horas extra registradas en el rango seleccionado.</p>
    </div>
<% } else { %>
<div class="card table-scroll">
    <table class="table-nomina">
        <thead><tr><th>Empleado</th><th>Departamento</th><th>Periodo</th><th>H. Ordinarias</th><th>H. Extra Total</th><th>25%</th><th>50%</th><th>75%</th><th>100%</th><th>Pago Total</th></tr></thead>
        <tbody>
        <% filas.forEach(r => { %>
            <tr class="avoid-break">
                <td class="font-medium"><%= r.nombre_completo %></td>
                <td><%= r.departamento %></td>
                <td class="whitespace-nowrap"><%= r.semana_inicio %> al <%= r.semana_fin %></td>
                <td><%= r.horas_ordinarias %> h</td>
                <td class="font-semibold"><%= r.horas_extras_total %> h</td>
                <td><%= r.horas_bucket_25 %> h</td>
                <td><%= r.horas_bucket_50 %> h</td>
                <td><%= r.horas_bucket_75 %> h</td>
                <td><%= r.horas_bucket_100 %> h</td>
                <td class="font-bold">L. <%= Number(r.pago_total_extras).toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
            </tr>
        <% }) %>
        </tbody>
        <tfoot>
            <tr class="font-bold bg-slate-50">
                <td colspan="4">TOTALES</td>
                <td><%= totales.horas_extras_total %> h</td>
                <td><%= totales.horas_bucket_25 %> h</td>
                <td><%= totales.horas_bucket_50 %> h</td>
                <td><%= totales.horas_bucket_75 %> h</td>
                <td><%= totales.horas_bucket_100 %> h</td>
                <td>L. <%= totales.pago_total_extras.toLocaleString('es-HN', {minimumFractionDigits:2}) %></td>
            </tr>
        </tfoot>
    </table>
</div>
<% } %>

<%- include('../partials/reporte_footer') %>
