<h1 class="text-2xl font-bold text-[#1B2A4A] mb-5">Nueva Planilla</h1>

<% if (errores && errores.length) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-300 text-red-700 px-4 py-3 text-sm">
        <ul class="list-disc pl-5"><% errores.forEach(e => { %><li><%= e %></li><% }) %></ul>
    </div>
<% } %>

<form method="POST" action="/planillas" class="card grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
    <div class="md:col-span-2">
        <label class="block text-sm font-medium mb-1">Nombre de la Planilla *</label>
        <input class="input" type="text" name="nombre" required placeholder="ej: Planilla Semanal 1 al 7 de Junio 2026">
    </div>
    <div class="md:col-span-2">
        <label class="block text-sm font-medium mb-1">Empresa</label>
        <select class="input" name="empresa_id">
            <option value="">Sin empresa asignada</option>
            <% empresas.forEach(e => { %>
                <option value="<%= e.id %>"><%= e.nombre %></option>
            <% }) %>
        </select>
        <% if (empresas.length === 0) { %>
            <p class="text-xs text-amber-600 mt-1">Todavia no hay empresas creadas — <a href="/empresas/nuevo" class="underline">crea una primero</a>.</p>
        <% } %>
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Tipo de Periodo *</label>
        <select class="input" name="tipo_periodo" required>
            <option value="SEMANAL">Semanal</option>
            <option value="QUINCENAL">Quincenal</option>
            <option value="MENSUAL">Mensual</option>
        </select>
    </div>
    <div></div>
    <div>
        <label class="block text-sm font-medium mb-1">Fecha Inicio *</label>
        <input class="input" type="date" name="fecha_inicio" required>
    </div>
    <div>
        <label class="block text-sm font-medium mb-1">Fecha Fin *</label>
        <input class="input" type="date" name="fecha_fin" required>
    </div>

    <div class="md:col-span-2 flex gap-3 pt-2">
        <button class="btn btn-primary">Crear y Procesar</button>
        <a href="/planillas" class="btn btn-outline">Cancelar</a>
    </div>
</form>
